<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PenPressureProfiler.Controls"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="PenPressureProfiler.MainWindow"
        Title="Pen Pressure Profiler"
        Width="1500" Height="800"
        MinWidth="1050" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <!-- Compact slider sizing for the Parameters card -->
        <x:Double x:Key="SliderHorizontalThumbWidth">12</x:Double>
        <x:Double x:Key="SliderHorizontalThumbHeight">12</x:Double>
        <x:Double x:Key="SliderOuterThumbWidth">12</x:Double>
        <x:Double x:Key="SliderOuterThumbHeight">12</x:Double>
        <x:Double x:Key="SliderInnerThumbWidth">8</x:Double>
        <x:Double x:Key="SliderInnerThumbHeight">8</x:Double>
        <x:Double x:Key="SliderTrackThemeHeight">3</x:Double>
    </Window.Resources>

    <DockPanel>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  RIBBON                                                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource RibbonBackgroundBrush}"
                BorderBrush="{DynamicResource RibbonBorderBrush}" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">

                <controls:RibbonGroup Header="PEN" Width="100">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse x:Name="ProximityDot" Width="8" Height="8" Fill="Gray"/>
                        <TextBlock x:Name="ProximityLabel" Text="Out" Foreground="{DynamicResource TertiaryTextBrush}"/>
                    </StackPanel>
                </controls:RibbonGroup>

                <controls:RibbonGroup Header="BUTTONS">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse x:Name="TipDot"     Width="8" Height="8" Fill="Gray"/>
                        <TextBlock Text="Tip" FontSize="11" Margin="0,0,8,0"/>
                        <Ellipse x:Name="Barrel1Dot" Width="8" Height="8" Fill="Gray"/>
                        <TextBlock Text="B1"  FontSize="11" Margin="0,0,8,0"/>
                        <Ellipse x:Name="Barrel2Dot" Width="8" Height="8" Fill="Gray"/>
                        <TextBlock Text="B2"  FontSize="11"/>
                    </StackPanel>
                </controls:RibbonGroup>

                <controls:RibbonGroup Header="ORIENTATION" Width="230">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock x:Name="RibbonAzLabel"  Text="Az: --"  FontSize="11"/>
                        <TextBlock x:Name="RibbonAltLabel" Text="Alt: --" FontSize="11"/>
                        <TextBlock x:Name="RibbonTxLabel"  Text="TX: --"  FontSize="11"/>
                        <TextBlock x:Name="RibbonTyLabel"  Text="TY: --"  FontSize="11"/>
                    </StackPanel>
                </controls:RibbonGroup>

                <!-- MODE: selects which right-panel + centre chart are visible -->
                <controls:RibbonGroup Header="MODE">
                    <ComboBox x:Name="comboBox_view_mode"
                              MinWidth="130" MinHeight="26"
                              Padding="8,2"
                              ItemTemplate="{StaticResource ComboTextTemplate}"
                              SelectionChanged="comboBox_view_mode_Changed"/>
                </controls:RibbonGroup>

                <!-- HELP: about dialog -->
                <controls:RibbonGroup Header="HELP" ShowSeparator="False">
                    <Button x:Name="btn_about" Content="About"
                            Click="btn_about_Click"
                            Padding="10,4" MinHeight="26"/>
                </controls:RibbonGroup>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT — 3 columns                                         -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>   <!-- Left: sensor cards     -->
                <ColumnDefinition Width="*"/>     <!-- Centre: charts         -->
                <ColumnDefinition Width="580"/>   <!-- Right: recording/stability -->
            </Grid.ColumnDefinitions>

            <!-- ── Left panel ─────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,10,12,12">

                    <!-- Pen card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="PEN" Classes="group-header"/>
							<ProgressBar x:Name="pressureBar"
                                         Minimum="0" Maximum="100" Value="0"
                                         Height="6" Margin="0,6,0,0"/>
							<Grid ColumnDefinitions="*,*">
                                <controls:LabeledReading x:Name="reading_pressure_raw"
                                                         Grid.Column="0"
                                                         Caption="Raw:"
                                                         CaptionWidth="62"/>
                                <controls:LabeledReading x:Name="reading_pressure_norm"
                                                         Grid.Column="1"
                                                         Caption="Norm:"
                                                         CaptionWidth="46"/>
                            </Grid>
                            <controls:LabeledReading x:Name="reading_pressure_smooth"
                                                     Caption="Smoothed:"/>
                            <controls:LabeledReading x:Name="reading_pen_rate"
                                                     Caption="Pen rate:"/>
                        </StackPanel>
                    </Border>

                    <!-- Scale card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="SCALE" Classes="group-header"/>
                            <controls:LabeledReading x:Name="reading_phys_pressure"
                                                     Caption="Phys pressure (gf):"/>
                            <controls:LabeledReading x:Name="reading_scale_rate"
                                                     Caption="Scale rate:"/>
                        </StackPanel>
                    </Border>

                    <!-- Device Inputs card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="DEVICES" Classes="group-header"/>

                            <!-- Tablet row -->
                            <controls:StatusDotRow x:Name="row_tablet"
                                                   Label="Tablet:"
                                                   Margin="0,0,0,8">
                                <ComboBox x:Name="ApiCombo"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"
                                          ItemTemplate="{StaticResource ComboTextTemplate}"
                                          ToolTip.Tip="WinTab — for tablets in WinTab mode.&#x0a;Avalonia Pointer — for tablets in Windows Ink mode."/>
                            </controls:StatusDotRow>

                            <!-- Scale row -->
                            <controls:StatusDotRow x:Name="row_scale"
                                                   Label="Scale:"
                                                   Margin="0,0,0,8"
                                                   ToolTip.Tip="Red: no COM port available, or last attempt failed.&#x0a;Yellow: COM port available but not reading.&#x0a;Green: actively reading.">
                                <Grid ColumnDefinitions="*,Auto">
                                    <ComboBox Grid.Column="0" x:Name="comboBox_comport"
                                              Margin="0,0,6,0" VerticalAlignment="Center"
                                              ItemTemplate="{StaticResource ComboTextTemplate}"/>
                                    <Button Grid.Column="1" x:Name="btn_scale_record"
                                            Content="Start" Click="btn_scale_record_Click"/>
                                </Grid>
                            </controls:StatusDotRow>

                            <!-- Logging row -->
                            <controls:StatusDotRow x:Name="row_logging"
                                                   Label="Logging:"
                                                   ToolTip.Tip="Green when CSV logging is active.">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Button Grid.Column="0" x:Name="btn_log_toggle"
                                            Content="Start Logging"
                                            Click="btn_log_toggle_Click"
                                            Margin="0,0,6,0"/>
                                    <Button Grid.Column="1" Content="📁"
                                            Click="btn_open_log_folder_Click"
                                            ToolTip.Tip="Open log folder" Padding="10,6"/>
                                </Grid>
                            </controls:StatusDotRow>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Centre: chart + always-on PenInputSurface overlay ──────── -->
            <!-- Chart visibility is driven by the ribbon VIEW selector:         -->
            <!-- Manual → plotView, Auto → stabilityPlotView,                        -->
            <!-- Threshold → threshPlotView, Monitor → monitorView (2 stacked).  -->
            <Grid Grid.Column="1">
                <sp:AvaPlot x:Name="plotView"/>
                <sp:AvaPlot x:Name="stabilityPlotView"  IsVisible="False"/>
                <sp:AvaPlot x:Name="threshPlotView" IsVisible="False"/>
                <!-- Monitor: two stacked live-scrolling charts -->
                <Grid x:Name="monitorView" IsVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <sp:AvaPlot x:Name="monitorPenPlot"   Grid.Row="0"/>
                    <sp:AvaPlot x:Name="monitorScalePlot" Grid.Row="1"/>
                </Grid>
                <!-- PenInputSurface: transparent overlay, always on top.
                     AvaloniaPointerSession attaches here. Must stay a plain
                     Border with NO interactive children. -->
                <Border x:Name="PenInputSurface" Background="Transparent"/>
            </Grid>

            <!-- ── Right panel: Manual / Auto / Threshold content ────────── -->
            <!-- The tab selector lives in the ribbon. Panels here are         -->
            <!-- visibility-toggled by btn_right_*_Click in code-behind.       -->
            <Grid Grid.Column="2">

                <!-- Recording panel -->
                <DockPanel x:Name="panel_right_recording" Margin="12,10,12,12">

                    <!-- Manual captures section -->
                    <controls:CaptureListSection x:Name="section_manual"
                                                 Header="MANUAL CAPTURES">
                        <controls:CaptureListSection.Actions>
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Record"
                                        Click="btn_record_Click"
                                        Margin="0,0,6,6"
                                        ToolTip.Tip="Record current (phys, logical) pair"/>
                                <controls:SortToggleButton x:Name="btn_manual_sort"
                                        Click="btn_manual_sort_Click"
                                        Margin="0,0,6,6"
                                        ToolTip.Tip="Toggle sort direction (display only — does not affect insertion order)"/>
                                <Button Content="Metadata…"
                                        Click="btn_edit_metadata_Click"
                                        Margin="0,0,6,6"
                                        ToolTip.Tip="Edit session metadata (brand, pen, tablet, …)"/>
                                <Button Content="Clear All" Click="btn_clear_all_Click" Margin="0,0,6,6"/>
                                <Button Content="Save…"     Click="btn_save_Click"     Margin="0,0,6,6"/>
                                <Button Content="Load…"     Click="btn_load_Click"     Margin="0,0,0,6"/>
                            </WrapPanel>
                        </controls:CaptureListSection.Actions>
                        <controls:CaptureListSection.Meta>
                            <TextBlock x:Name="txt_record_count"
                                       Text="0 records" Opacity="0.7"/>
                        </controls:CaptureListSection.Meta>
                        <controls:CaptureListSection.Body>
                            <ListBox x:Name="listBox_records"
                                     Classes="capture-list">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding"   Value="0"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <controls:EstimateCard
                                            Number="{Binding Number}"
                                            Fields="{Binding Fields}"
                                            DeleteClicked="btn_manual_card_delete_Click"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </controls:CaptureListSection.Body>
                    </controls:CaptureListSection>

                </DockPanel>

                <!-- Stability panel -->
                <DockPanel x:Name="panel_right_stability"
                           IsVisible="False"
                           Margin="12,10,12,12">

                        <!-- Stability controls card -->
                        <Border Classes="card" DockPanel.Dock="Top">
                            <StackPanel>
                                <TextBlock Text="STABILITY DETECTION" Classes="group-header"/>
                                <Button x:Name="btn_stability_enable"
                                        Content="Start"
                                        Click="btn_stability_enable_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Stability parameters card (collapsible, collapsed by default) -->
                        <Border Classes="card" DockPanel.Dock="Top">
                            <StackPanel>

                                <!-- Clickable header (chevron + title) -->
                                <Button x:Name="btn_auto_params_toggle"
                                        Classes="collapsible-header"
                                        Click="btn_auto_params_toggle_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock x:Name="chevron_auto_params"
                                                   Text="▸"
                                                   Classes="group-header"
                                                   Margin="0"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="STABILITY PARAMETERS"
                                                   Classes="group-header"
                                                   Margin="0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Slider rows (collapsed by default) -->
                                <StackPanel x:Name="panel_auto_params"
                                            IsVisible="False"
                                            Margin="0,8,0,0">

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Pen tolerance:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_penTolerance"
                                            Minimum="0.001" Maximum="0.10" Value="0.005"
                                            ValueChanged="OnStabilitySliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_penTolerance"
                                               Text="0.5%" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Scale tolerance:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_scaleTolerance"
                                            Minimum="0.1" Maximum="30" Value="0.25"
                                            ValueChanged="OnStabilitySliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_scaleTolerance"
                                               Text="0.25 gf" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Stable duration:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_stableDuration"
                                            Minimum="100" Maximum="2000" Value="500"
                                            ValueChanged="OnStabilitySliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_stableDuration"
                                               Text="500 ms" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Min capture gap:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_minGap"
                                            Minimum="200" Maximum="3000" Value="500"
                                            ValueChanged="OnStabilitySliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_minGap"
                                               Text="500 ms" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Stability captures section -->
                        <controls:CaptureListSection Header="STABILITY CAPTURES">
                            <controls:CaptureListSection.Actions>
                                <WrapPanel Orientation="Horizontal">
                                    <Button x:Name="btn_stability_record"
                                            Content="Record"
                                            Click="btn_stability_record_Click"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Force-capture the current (phys, logical-smoothed) pair, bypassing stability detection."/>
                                    <controls:SortToggleButton x:Name="btn_stability_sort"
                                            Click="btn_stability_sort_Click"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Toggle sort direction"/>
                                    <Button Content="Edit…"
                                            Click="btn_stability_edit_Click"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Open editor to delete individual captures"/>
                                    <Button Content="Clear All" Click="btn_stability_clear_Click" Margin="0,0,6,6"/>
                                    <Button Content="Save…"     Click="btn_stability_save_Click"  Margin="0,0,6,6"/>
                                    <Button Content="Load…"     Click="btn_stability_load_Click"  Margin="0,0,0,6"/>
                                </WrapPanel>
                            </controls:CaptureListSection.Actions>
                            <controls:CaptureListSection.Meta>
                                <Grid ColumnDefinitions="*,*">
                                    <controls:LabeledReading x:Name="reading_stability_unique"
                                                             Grid.Column="0"
                                                             Caption="Unique:"
                                                             CaptionWidth="58"/>
                                    <controls:LabeledReading x:Name="reading_stability_total"
                                                             Grid.Column="1"
                                                             Caption="Total:"
                                                             CaptionWidth="48"/>
                                </Grid>
                            </controls:CaptureListSection.Meta>
                            <controls:CaptureListSection.Body>
                                <ListBox x:Name="listBox_stability_captures"
                                         Classes="capture-list">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding"   Value="0"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <controls:EstimateCard
                                                Number="{Binding Number}"
                                                Fields="{Binding Fields}"
                                                DeleteClicked="btn_stability_card_delete_Click"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </controls:CaptureListSection.Body>
                        </controls:CaptureListSection>

                </DockPanel>

                <!-- Threshold panel — wraps IAF (from above) and MAX (from below) -->
                <DockPanel x:Name="panel_right_threshold"
                           IsVisible="False"
                           Margin="12,10,12,12">

                        <!-- Mode picker + detection card -->
                        <Border Classes="card" DockPanel.Dock="Top">
                            <StackPanel>
                                <TextBlock Text="THRESHOLD DETECTION" Classes="group-header"/>

                                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0" Text="Mode:"
                                               Classes="reading-caption"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="comboBox_threshold_mode"
                                              Margin="6,0,0,0" VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              ItemTemplate="{StaticResource ComboTextTemplate}"
                                              SelectionChanged="comboBox_threshold_mode_Changed"
                                              ToolTip.Tip="IAF from above: release sweep to find activation gf.&#x0a;MAX from below: push sweep to find saturation gf."/>
                                </Grid>

                                <!-- Armed indicator — meaning is mode-dependent (see txt_threshold_armed) -->
                                <controls:StatusDotRow x:Name="row_threshold_armed"
                                                       Margin="0,0,0,8"
                                                       IsVisible="False"
                                                       ToolTip.Tip="Green when the active mode is ready to record its next estimate. Gray text below says what the user needs to do.">
                                    <TextBlock x:Name="txt_threshold_armed"
                                               Text="Not armed"
                                               VerticalAlignment="Center" FontSize="11"
                                               Opacity="0.8"/>
                                </controls:StatusDotRow>

                                <Button x:Name="btn_threshold_enable"
                                        Content="Start"
                                        Click="btn_threshold_enable_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Results section -->
                        <controls:CaptureListSection x:Name="section_threshold"
                                                     Header="CAPTURES">
                            <controls:CaptureListSection.Actions>
                                <WrapPanel Orientation="Horizontal">
                                    <Button x:Name="btn_threshold_record"
                                            Content="Record"
                                            Click="btn_threshold_record_Click"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Force-record the current scale force as an estimate, bypassing sweep detection."/>
                                    <Button Content="Clear All" Click="btn_threshold_clear_Click" Margin="0,0,0,6"/>
                                </WrapPanel>
                            </controls:CaptureListSection.Actions>
                            <controls:CaptureListSection.Meta>
                                <StackPanel>
                                    <controls:LabeledReading x:Name="reading_threshold_count"
                                                             Caption="Progress:"
                                                             Margin="0,0,0,2"/>
                                    <controls:LabeledReading x:Name="reading_threshold_median"
                                                             Caption="Median:"/>
                                </StackPanel>
                            </controls:CaptureListSection.Meta>
                            <controls:CaptureListSection.Body>
                                <ListBox x:Name="listBox_threshold_estimates"
                                         Classes="capture-list">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding"   Value="0"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <controls:EstimateCard
                                                Number="{Binding Number}"
                                                Fields="{Binding Fields}"
                                                DeleteClicked="btn_card_delete_Click"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </controls:CaptureListSection.Body>
                        </controls:CaptureListSection>

                </DockPanel>

                <!-- Monitor panel -->
                <ScrollViewer x:Name="panel_right_monitor"
                              IsVisible="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,12">

                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Text="MONITOR" Classes="group-header"/>
                                <CheckBox x:Name="check_monitor_overlay"
                                          Content="Overlay traces"
                                          IsCheckedChanged="check_monitor_overlay_Changed"
                                          Margin="0,0,0,8"
                                          ToolTip.Tip="When on: pen (left axis, 0–1) and scale (right axis, gf) share one chart with dual y-axes. When off: two stacked charts."/>
                                <Button x:Name="btn_monitor_clear"
                                        Content="Clear traces"
                                        Click="btn_monitor_clear_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</Window>

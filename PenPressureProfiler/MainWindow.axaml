<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PenPressureProfiler.Controls"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="PenPressureProfiler.MainWindow"
        Title="Pen Pressure Profiler"
        Width="1500" Height="800"
        MinWidth="1050" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        FontSize="13"
        FontFamily="Segoe UI Variable,Segoe UI,sans-serif"
        Background="Transparent"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <!-- Compact slider sizing for the Parameters card -->
        <x:Double x:Key="SliderHorizontalThumbWidth">12</x:Double>
        <x:Double x:Key="SliderHorizontalThumbHeight">12</x:Double>
        <x:Double x:Key="SliderOuterThumbWidth">12</x:Double>
        <x:Double x:Key="SliderOuterThumbHeight">12</x:Double>
        <x:Double x:Key="SliderInnerThumbWidth">8</x:Double>
        <x:Double x:Key="SliderInnerThumbHeight">8</x:Double>
        <x:Double x:Key="SliderTrackThemeHeight">3</x:Double>
    </Window.Resources>

    <DockPanel>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  RIBBON                                                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">

                <StackPanel Width="100">
                    <TextBlock Text="PEN" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse x:Name="ProximityDot" Width="8" Height="8" Fill="Gray"/>
                        <TextBlock x:Name="ProximityLabel" Text="Out" Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD"/>

                <StackPanel>
                    <TextBlock Text="BUTTONS" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse x:Name="TipDot"     Width="8" Height="8" Fill="Gray"/>
                        <TextBlock Text="Tip" FontSize="11" Margin="0,0,8,0"/>
                        <Ellipse x:Name="Barrel1Dot" Width="8" Height="8" Fill="Gray"/>
                        <TextBlock Text="B1"  FontSize="11" Margin="0,0,8,0"/>
                        <Ellipse x:Name="Barrel2Dot" Width="8" Height="8" Fill="Gray"/>
                        <TextBlock Text="B2"  FontSize="11"/>
                    </StackPanel>
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD"/>

                <StackPanel Width="230">
                    <TextBlock Text="ORIENTATION" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock x:Name="RibbonAzLabel"  Text="Az: --"  FontSize="11"/>
                        <TextBlock x:Name="RibbonAltLabel" Text="Alt: --" FontSize="11"/>
                        <TextBlock x:Name="RibbonTxLabel"  Text="TX: --"  FontSize="11"/>
                        <TextBlock x:Name="RibbonTyLabel"  Text="TY: --"  FontSize="11"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT — 3 columns                                         -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>   <!-- Left: sensor cards     -->
                <ColumnDefinition Width="*"/>     <!-- Centre: charts         -->
                <ColumnDefinition Width="580"/>   <!-- Right: recording/sweep -->
            </Grid.ColumnDefinitions>

            <!-- ── Left panel ─────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,10,12,12">

                    <!-- Pen card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Pen" Classes="group-header"/>
                            <controls:LabeledReading x:Name="reading_pressure_raw"
                                                     Caption="Log Pressure (raw):"/>
                            <controls:LabeledReading x:Name="reading_pressure_norm"
                                                     Caption="Log Pressure (norm):"/>
                            <controls:LabeledReading x:Name="reading_pressure_smooth"
                                                     Caption="Log Pressure (smooth):"/>
                            <controls:LabeledReading x:Name="reading_pen_rate"
                                                     Caption="Pen rate:"/>
                            <ProgressBar x:Name="pressureBar"
                                         Minimum="0" Maximum="100" Value="0"
                                         Height="6" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Scale card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Scale" Classes="group-header"/>
                            <controls:LabeledReading x:Name="reading_phys_pressure"
                                                     Caption="Phys pressure (gf):"/>
                            <controls:LabeledReading x:Name="reading_scale_rate"
                                                     Caption="Scale rate:"/>
                        </StackPanel>
                    </Border>

                    <!-- Chart card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Chart" Classes="group-header"/>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Axis range:"
                                           Classes="reading-caption"
                                           VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="comboBox_chart_axis"
                                          Margin="6,0,0,0" VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="comboBox_chart_axis_Changed"
                                          ToolTip.Tip="Applies to whichever chart is currently visible (driven by the Manual / Auto tab)."/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Device Inputs card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Device Inputs" Classes="group-header"/>

                            <!-- Tablet row -->
                            <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0" Text="Tablet:"
                                           Classes="reading-caption"
                                           VerticalAlignment="Center"/>
                                <Ellipse Grid.Column="1" x:Name="dot_pen"
                                         Width="8" Height="8" Fill="Gray"
                                         Margin="6,0,8,0" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="2" x:Name="ApiCombo"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="WinTab — for tablets in WinTab mode.&#x0a;Avalonia Pointer — for tablets in Windows Ink mode."/>
                            </Grid>

                            <!-- Scale row -->
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0" Text="Scale:"
                                           Classes="reading-caption"
                                           VerticalAlignment="Center"/>
                                <Ellipse Grid.Column="1" x:Name="dot_scale"
                                         Width="8" Height="8" Fill="Gray"
                                         Margin="6,0,8,0" VerticalAlignment="Center"
                                         ToolTip.Tip="Red: no COM port available, or last attempt failed.&#x0a;Yellow: COM port available but not reading.&#x0a;Green: actively reading."/>
                                <ComboBox Grid.Column="2" x:Name="comboBox_comport"
                                          Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" x:Name="btn_scale_record"
                                        Content="Read" Click="btn_scale_record_Click"/>
                            </Grid>

                            <!-- Logging row -->
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="Logging:"
                                           Classes="reading-caption"
                                           VerticalAlignment="Center"/>
                                <Ellipse Grid.Column="1" x:Name="dot_log"
                                         Width="8" Height="8" Fill="Gray"
                                         Margin="6,0,8,0" VerticalAlignment="Center"
                                         ToolTip.Tip="Green when CSV logging is active."/>
                                <Button Grid.Column="2" x:Name="btn_log_toggle"
                                        Content="Start Logging"
                                        Click="btn_log_toggle_Click"
                                        Margin="0,0,6,0"/>
                                <Button Grid.Column="3" Content="📁"
                                        Click="btn_open_log_folder_Click"
                                        ToolTip.Tip="Open log folder" Padding="10,6"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Centre: chart + always-on PenInputSurface overlay ──────── -->
            <!-- Chart visibility is driven by the right-panel tab:             -->
            <!-- Manual → plotView, Auto → sweepPlotView,                       -->
            <!-- IAF → iafPlotView, MAX → maxPlotView.                          -->
            <Grid Grid.Column="1">
                <sp:AvaPlot x:Name="plotView"/>
                <sp:AvaPlot x:Name="sweepPlotView" IsVisible="False"/>
                <sp:AvaPlot x:Name="iafPlotView"   IsVisible="False"/>
                <sp:AvaPlot x:Name="maxPlotView"   IsVisible="False"/>
                <!-- PenInputSurface: transparent overlay, always on top.
                     AvaloniaPointerSession attaches here. Must stay a plain
                     Border with NO interactive children. -->
                <Border x:Name="PenInputSurface" Background="Transparent"/>
            </Grid>

            <!-- ── Right panel: Recording / Sweep tabs ────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Tab buttons -->
                    <RowDefinition Height="*"/>     <!-- Panel content -->
                </Grid.RowDefinitions>

                <!-- Right tab buttons -->
                <Border Grid.Row="0" Background="#F0F0F0"
                        BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button x:Name="btn_right_recording" Content="Manual"
                                Click="btn_right_recording_Click"
                                Classes="tab-active" Padding="10,4" MinHeight="26"/>
                        <Button x:Name="btn_right_sweep" Content="Auto"
                                Click="btn_right_sweep_Click"
                                Padding="10,4" MinHeight="26"/>
                        <Button x:Name="btn_right_iaf" Content="IAF"
                                Click="btn_right_iaf_Click"
                                Padding="10,4" MinHeight="26"/>
                        <Button x:Name="btn_right_max" Content="MAX"
                                Click="btn_right_max_Click"
                                Padding="10,4" MinHeight="26"/>
                    </StackPanel>
                </Border>

                <!-- Recording panel (Phase 4-5 content) -->
                <ScrollViewer Grid.Row="1" x:Name="panel_right_recording"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,12">

                        <!-- Manual captures card -->
                        <Border Classes="card">
                            <StackPanel>

                                <!-- Header: title + ↑ Force + Metadata… -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Manual captures"
                                               Classes="group-header" Margin="0"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            x:Name="btn_manual_sort"
                                            Content="↑ Force"
                                            Click="btn_manual_sort_Click"
                                            Padding="6,2" MinHeight="22"
                                            Margin="0,0,4,0"
                                            ToolTip.Tip="Toggle sort direction (display only — does not affect insertion order)"/>
                                    <Button Grid.Column="2"
                                            Content="Metadata…"
                                            Click="btn_edit_metadata_Click"
                                            Padding="6,2" MinHeight="22"
                                            ToolTip.Tip="Edit session metadata (brand, pen, tablet, …)"/>
                                </Grid>

                                <!-- Primary actions -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <Button Content="Record"
                                            Click="btn_record_Click"
                                            ToolTip.Tip="Record current (phys, logical) pair"/>
                                    <Button Content="− Last"
                                            Click="btn_clear_last_Click"/>
                                </StackPanel>

                                <!-- Count -->
                                <TextBlock x:Name="txt_record_count"
                                           Text="0 records" Opacity="0.7"
                                           Margin="0,0,0,6"/>

                                <!-- ListBox -->
                                <ListBox x:Name="listBox_records"
                                         Height="280" FontSize="11"
                                         FontFamily="Consolas,Courier New,monospace">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding"   Value="4,1"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListBox.Styles>
                                </ListBox>

                                <!-- File ops -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <Button Content="Clear All" Click="btn_clear_all_Click"/>
                                    <Button Content="Save…"     Click="btn_save_Click"/>
                                    <Button Content="Load…"     Click="btn_load_Click"/>
                                </StackPanel>

                                <!-- Status -->
                                <TextBlock x:Name="txt_file_status"
                                           Text="No file loaded" FontSize="11" Opacity="0.6"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Sweep panel -->
                <ScrollViewer Grid.Row="1" x:Name="panel_right_sweep"
                              IsVisible="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,12">

                        <!-- Sweep controls card -->
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Text="Auto Detection" Classes="group-header"/>
                                <Button x:Name="btn_sweep_enable"
                                        Content="Start Auto-Capture"
                                        Click="btn_sweep_enable_Click"/>
                                <CheckBox x:Name="check_altitude_color"
                                          Content="Color dots by altitude"
                                          Margin="0,8,0,0"
                                          IsCheckedChanged="check_altitude_color_Changed"
                                          ToolTip.Tip="90° (vertical) → black, 60° (and lower) → cornflower blue."/>
                            </StackPanel>
                        </Border>

                        <!-- Sweep parameters card (collapsible, collapsed by default) -->
                        <Border Classes="card">
                            <StackPanel>

                                <!-- Clickable header (chevron + title) -->
                                <Button x:Name="btn_auto_params_toggle"
                                        Classes="collapsible-header"
                                        Click="btn_auto_params_toggle_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock x:Name="chevron_auto_params"
                                                   Text="▸"
                                                   Classes="group-header"
                                                   Margin="0"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Auto Parameters"
                                                   Classes="group-header"
                                                   Margin="0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Slider rows (collapsed by default) -->
                                <StackPanel x:Name="panel_auto_params"
                                            IsVisible="False"
                                            Margin="0,8,0,0">

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Pen tolerance:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_penTolerance"
                                            Minimum="0.001" Maximum="0.10" Value="0.005"
                                            ValueChanged="OnSweepSliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_penTolerance"
                                               Text="0.5%" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Scale tolerance:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_scaleTolerance"
                                            Minimum="0.1" Maximum="30" Value="0.25"
                                            ValueChanged="OnSweepSliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_scaleTolerance"
                                               Text="0.25 gf" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Stable duration:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_stableDuration"
                                            Minimum="100" Maximum="2000" Value="500"
                                            ValueChanged="OnSweepSliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_stableDuration"
                                               Text="500 ms" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                <Grid ColumnDefinitions="130,*,60" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="Min capture gap:"
                                               Classes="reading-caption"/>
                                    <Slider Grid.Column="1" x:Name="slider_minGap"
                                            Minimum="200" Maximum="3000" Value="500"
                                            ValueChanged="OnSweepSliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="label_minGap"
                                               Text="500 ms" Classes="reading-value"
                                               Margin="6,0,0,0"/>
                                </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Captures list -->
                        <Border Classes="card">
                            <StackPanel>

                                <!-- Header: title + sort toggle + edit button -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Auto captures"
                                               Classes="group-header" Margin="0"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            x:Name="btn_sweep_sort"
                                            Content="↑ Force"
                                            Click="btn_sweep_sort_Click"
                                            Padding="6,2" MinHeight="22"
                                            Margin="0,0,4,0"
                                            ToolTip.Tip="Toggle sort direction"/>
                                    <Button Grid.Column="2"
                                            Content="Edit…"
                                            Click="btn_sweep_edit_Click"
                                            Padding="6,2" MinHeight="22"
                                            ToolTip.Tip="Open editor to delete individual captures"/>
                                </Grid>

                                <!-- Count -->
                                <controls:LabeledReading x:Name="reading_sweep_unique"
                                                         Caption="Unique:"
                                                         Margin="0,0,0,2"/>
                                <controls:LabeledReading x:Name="reading_sweep_total"
                                                         Caption="Total:"
                                                         Margin="0,0,0,6"/>

                                <!-- ListBox -->
                                <ListBox x:Name="listBox_sweep_captures"
                                         Height="280" FontSize="11"
                                         SelectionMode="Multiple"
                                         FontFamily="Consolas,Courier New,monospace">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding"   Value="4,1"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListBox.Styles>
                                </ListBox>

                                <!-- File ops -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <Button Content="Clear All" Click="btn_sweep_clear_Click"/>
                                    <Button Content="Save…"     Click="btn_sweep_save_Click"/>
                                    <Button Content="Load…"     Click="btn_sweep_load_Click"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- IAF panel -->
                <ScrollViewer Grid.Row="1" x:Name="panel_right_iaf"
                              IsVisible="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,12">

                        <!-- IAF detection card -->
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Text="Auto IAF" Classes="group-header"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="11"
                                           Margin="0,0,0,8"
                                           Text="Press the pen until at least 80 gf, then release fully to zero. Repeat 10 times. Each release produces one IAF estimate via linear extrapolation; the final IAF is the median."/>
                                <Button x:Name="btn_iaf_enable"
                                        Content="Start Auto-IAF"
                                        Click="btn_iaf_enable_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- IAF results card -->
                        <Border Classes="card">
                            <StackPanel>

                                <!-- Header -->
                                <TextBlock Text="IAF estimates" Classes="group-header"/>

                                <!-- Counters -->
                                <controls:LabeledReading x:Name="reading_iaf_count"
                                                         Caption="Progress:"
                                                         Margin="0,0,0,2"/>
                                <controls:LabeledReading x:Name="reading_iaf_median"
                                                         Caption="Median:"
                                                         Margin="0,0,0,6"/>

                                <!-- Estimate list -->
                                <ListBox x:Name="listBox_iaf_estimates"
                                         Height="280" FontSize="11"
                                         FontFamily="Consolas,Courier New,monospace">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding"   Value="4,1"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListBox.Styles>
                                </ListBox>

                                <!-- File ops -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <Button Content="− Last"
                                            Click="btn_iaf_remove_last_Click"
                                            ToolTip.Tip="Drop the most recent estimate"/>
                                    <Button Content="Clear All" Click="btn_iaf_clear_Click"/>
                                </StackPanel>

                                <!-- Status -->
                                <TextBlock x:Name="txt_iaf_status"
                                           Text="Idle." FontSize="11" Opacity="0.6"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- MAX panel -->
                <ScrollViewer Grid.Row="1" x:Name="panel_right_max"
                              IsVisible="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,12">

                        <!-- MAX detection card -->
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Text="Auto MAX" Classes="group-header"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="11"
                                           Margin="0,0,0,8"
                                           Text="Press the pen until the logical pressure reaches 100% (saturation), then lift fully. Repeat 10 times. Each transition into saturation produces one MAX gf estimate via linear extrapolation; the final MAX is the median."/>
                                <Button x:Name="btn_max_enable"
                                        Content="Start Auto-MAX"
                                        Click="btn_max_enable_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- MAX results card -->
                        <Border Classes="card">
                            <StackPanel>

                                <TextBlock Text="MAX estimates" Classes="group-header"/>

                                <controls:LabeledReading x:Name="reading_max_count"
                                                         Caption="Progress:"
                                                         Margin="0,0,0,2"/>
                                <controls:LabeledReading x:Name="reading_max_median"
                                                         Caption="Median:"
                                                         Margin="0,0,0,6"/>

                                <ListBox x:Name="listBox_max_estimates"
                                         Height="280" FontSize="11"
                                         FontFamily="Consolas,Courier New,monospace">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding"   Value="4,1"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListBox.Styles>
                                </ListBox>

                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <Button Content="− Last"
                                            Click="btn_max_remove_last_Click"
                                            ToolTip.Tip="Drop the most recent estimate"/>
                                    <Button Content="Clear All" Click="btn_max_clear_Click"/>
                                </StackPanel>

                                <TextBlock x:Name="txt_max_status"
                                           Text="Idle." FontSize="11" Opacity="0.6"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</Window>

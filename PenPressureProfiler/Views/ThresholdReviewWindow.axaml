<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="PenPressureProfiler.Views.ThresholdReviewWindow"
        Title="Review Capture"
        Width="1200" Height="600"
        MinWidth="820" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Title + focus controls -->
        <Border Grid.Row="0" Background="{DynamicResource RibbonBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" x:Name="txt_title"
                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <TextBlock Text="Focus:" VerticalAlignment="Center" Opacity="0.7"/>
                    <Button Content="1 s"  Click="Focus1s_Click"
                            ToolTip.Tip="Zoom the chart to the last 1 s before detection."/>
                    <Button Content="3 s"  Click="Focus3s_Click"
                            ToolTip.Tip="Zoom the chart to the last 3 s before detection."/>
                    <Button Content="Full" Click="FocusFull_Click"
                            ToolTip.Tip="Show the whole recorded buffer."/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Table (left) + time-series chart (right) -->
        <Grid Grid.Row="1" ColumnDefinitions="600,4,*">

            <DockPanel Grid.Column="0" Margin="4">
                <!-- Column header -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource RibbonBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                        Padding="4,3">
                    <Grid ColumnDefinitions="86,60,56,44,50,56,60,32,64">
                        <TextBlock Grid.Column="0" Text="time"     FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="t (ms)"   FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="Δ ms"     FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="src"      FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0"/>
                        <TextBlock Grid.Column="4" Text="raw"      FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="norm%"    FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="smooth%"  FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                        <TextBlock Grid.Column="7" Text="tip"      FontSize="11" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Grid.Column="8" Text="gf"       FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <ListBox x:Name="listBox_rows">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding"   Value="0"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding RowBackground}" Padding="4,1">
                                <Grid ColumnDefinitions="86,60,56,44,50,56,60,32,64">
                                    <TextBlock Grid.Column="0" Text="{Binding Time}"    FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TimeMs}"  FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DeltaMs}" FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Source}"  FontSize="11" Margin="6,0,0,0" Foreground="{Binding SourceColor}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Raw}"     FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Norm}"    FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="6" Text="{Binding Smooth}"  FontSize="11" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="7" Text="{Binding Tip}"     FontSize="11" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="8" Text="{Binding Gf}"      FontSize="11" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns"
                          Background="{DynamicResource DividerBrush}" HorizontalAlignment="Stretch"/>

            <sp:AvaPlot x:Name="reviewPlot" Grid.Column="2" Margin="4"/>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource RibbonBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0"
                Padding="8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" x:Name="txt_footer"
                           VerticalAlignment="Center" Opacity="0.75" FontSize="11"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Content="Save…" Click="Save_Click"
                            ToolTip.Tip="Save this capture's raw pen/scale samples to a JSON file for later analysis."/>
                    <Button Content="Close" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PenPressureProfiler.Controls"
        x:Class="PenPressureProfiler.Views.MetadataEditWindow"
        Title="Edit Session Metadata"
        Width="460" Height="640"
        MinWidth="380" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="*,Auto">

        <!-- Fields -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12,16,12">
            <StackPanel>
                <controls:LabeledField x:Name="field_brand"       Label="Brand:"/>
                <controls:LabeledField x:Name="field_pen"         Label="Pen:"/>
                <controls:LabeledField x:Name="field_inventoryid" Label="Inventory ID:"/>
                <controls:LabeledField x:Name="field_date"        Label="Date:"/>
                <controls:LabeledField x:Name="field_tablet"      Label="Tablet:"/>
                <controls:LabeledField x:Name="field_driver"      Label="Driver:"/>
                <controls:LabeledField x:Name="field_os"          Label="OS:"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="1" Background="{DynamicResource RibbonBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0"
                Padding="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" Spacing="6">
                    <Button Content="Done"
                            Click="Done_Click"
                            ToolTip.Tip="Apply changes"/>
                    <Button Content="Cancel"
                            Click="Cancel_Click"
                            ToolTip.Tip="Discard changes"/>
                </StackPanel>
                <TextBlock x:Name="error_text"
                           IsVisible="False"
                           Foreground="#D9534F"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>

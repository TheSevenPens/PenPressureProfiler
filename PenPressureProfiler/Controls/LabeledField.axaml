<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PenPressureProfiler.Controls.LabeledField">
    <StackPanel Margin="0,0,0,8">
        <TextBlock Classes="field-label"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <TextBox Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"/>
    </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PenPressureProfiler.Controls.LabeledReading">
    <Grid Margin="0,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding CaptionWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="CaptionBlock" Grid.Column="0" Classes="reading-caption"/>
        <TextBlock x:Name="ValueBlock"   Grid.Column="1" Classes="reading-value"/>
    </Grid>
</UserControl>

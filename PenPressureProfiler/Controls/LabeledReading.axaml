<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PenPressureProfiler.Controls.LabeledReading">
    <Grid Margin="0,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding CaptionWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="CaptionBlock" Grid.Column="0" Classes="reading-caption"/>
        <!-- Value sits next to the caption (left-aligned) with tabular figures;
             when ValueWidth is set (NaN = auto) the slot is fixed so changing
             readings don't reflow neighbouring content. -->
        <TextBlock x:Name="ValueBlock"   Grid.Column="1" Classes="reading-value"
                   Width="{Binding ValueWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   TextAlignment="Left" FontFeatures="+tnum"/>
    </Grid>
</UserControl>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PenPressureProfiler.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />

        <!-- ── Typography ──────────────────────────────────────────────────── -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.group-header">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.reading-caption">
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity"           Value="0.7"/>
        </Style>
        <Style Selector="TextBlock.reading-value">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity"    Value="0.7"/>
            <Setter Property="Margin"     Value="0,8,0,3"/>
        </Style>

        <!-- ── TextBox ─────────────────────────────────────────────────────── -->
        <Style Selector="TextBox">
            <Setter Property="Padding"   Value="6,2"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>

        <!-- ── Buttons ─────────────────────────────────────────────────────── -->
        <Style Selector="Button">
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="MinHeight"    Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.tab-active">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Small ✕ icon button on per-item cards (e.g. Threshold estimate list) -->
        <Style Selector="Button.card-delete">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="8,2"/>
            <Setter Property="MinHeight"         Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Foreground"        Value="#9CA3AF"/>
        </Style>
        <Style Selector="Button.card-delete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33DC2626"/>
        </Style>
        <Style Selector="Button.card-delete:pointerover">
            <Setter Property="Foreground" Value="#DC2626"/>
        </Style>

        <!-- Header-style button used for collapsible card sections -->
        <Style Selector="Button.collapsible-header">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="Padding"                   Value="0"/>
            <Setter Property="MinHeight"                 Value="0"/>
            <Setter Property="HorizontalAlignment"       Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                    Value="Hand"/>
        </Style>
        <Style Selector="Button.collapsible-header:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#10000000"/>
        </Style>

        <!-- ── Cards ───────────────────────────────────────────────────────── -->
        <Style Selector="Border.card">
            <Setter Property="Background"   Value="#14000000"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="12"/>
            <Setter Property="Margin"       Value="0,8,0,0"/>
        </Style>

    </Application.Styles>
</Application>

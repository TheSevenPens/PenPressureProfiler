<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PenPressureProfiler.Controls"
             x:Class="PenPressureProfiler.App"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Pin the Fluent accent colour so the UI looks identical on
                 every machine instead of inheriting the user's Windows accent
                 (Settings → Personalization → Colors). Base + the light/dark
                 shade ramp the theme expects; matched to the chart-data blue
                 (#2563EB) so accented controls agree with the plots. -->
            <Color x:Key="SystemAccentColor">#2563EB</Color>
            <Color x:Key="SystemAccentColorDark1">#1D4ED8</Color>
            <Color x:Key="SystemAccentColorDark2">#1E40AF</Color>
            <Color x:Key="SystemAccentColorDark3">#1E3A8A</Color>
            <Color x:Key="SystemAccentColorLight1">#3B82F6</Color>
            <Color x:Key="SystemAccentColorLight2">#60A5FA</Color>
            <Color x:Key="SystemAccentColorLight3">#93C5FD</Color>

            <!-- App-controlled theme brushes. Defined per-variant so they
                 track light/dark automatically without relying on the exact
                 spelling of Fluent's built-in resource keys. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="RibbonBackgroundBrush" Color="#F5F5F5"/>
                    <SolidColorBrush x:Key="RibbonBorderBrush"     Color="#CCCCCC"/>
                    <SolidColorBrush x:Key="DividerBrush"          Color="#DDDDDD"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush"   Color="#14000000"/>
                    <SolidColorBrush x:Key="PrimaryTextBrush"      Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush"    Color="#555555"/>
                    <SolidColorBrush x:Key="TertiaryTextBrush"     Color="#888888"/>
                    <SolidColorBrush x:Key="SubtleHoverBrush"      Color="#10000000"/>
                    <SolidColorBrush x:Key="CardDeleteBrush"       Color="#9CA3AF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="RibbonBackgroundBrush" Color="#2A2A2A"/>
                    <SolidColorBrush x:Key="RibbonBorderBrush"     Color="#3F3F3F"/>
                    <SolidColorBrush x:Key="DividerBrush"          Color="#3F3F3F"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush"   Color="#1AFFFFFF"/>
                    <SolidColorBrush x:Key="PrimaryTextBrush"      Color="#F0F0F0"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush"    Color="#B0B0B0"/>
                    <SolidColorBrush x:Key="TertiaryTextBrush"     Color="#909090"/>
                    <SolidColorBrush x:Key="SubtleHoverBrush"      Color="#18FFFFFF"/>
                    <SolidColorBrush x:Key="CardDeleteBrush"       Color="#9CA3AF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <controls:StatusDotBrushConverter x:Key="StatusDotBrush"/>

            <!-- Renders a ComboBox's (string) items with an explicitly themed
                 foreground. Avalonia uses ItemTemplate for both the dropdown
                 list and the closed selection box, so this guarantees the
                 selected text stays readable in dark mode (the default
                 selection-box presenter can render near-black). -->
            <DataTemplate x:Key="ComboTextTemplate">
                <TextBlock Text="{Binding}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />

        <!-- ── Typography ──────────────────────────────────────────────────── -->
        <!-- Single source of truth for the UI font. "Segoe UI" (not the Win11
             "Variable" cut) so it resolves identically across machines and
             matches the ScottPlot chart font set in Program.Main. -->
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Segoe UI,sans-serif"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.group-header">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.reading-caption">
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity"           Value="0.7"/>
        </Style>
        <Style Selector="TextBlock.reading-value">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity"    Value="0.7"/>
            <Setter Property="Margin"     Value="0,8,0,3"/>
        </Style>

        <!-- ── TextBox ─────────────────────────────────────────────────────── -->
        <Style Selector="TextBox">
            <Setter Property="Padding"   Value="6,2"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>

        <!-- ── Buttons ─────────────────────────────────────────────────────── -->
        <Style Selector="Button">
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="MinHeight"    Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.tab-active">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Small ✕ icon button on per-item cards (e.g. Threshold estimate list) -->
        <Style Selector="Button.card-delete">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="8,0"/>
            <Setter Property="MinHeight"         Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Foreground"        Value="{DynamicResource CardDeleteBrush}"/>
        </Style>
        <Style Selector="Button.card-delete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33DC2626"/>
        </Style>
        <Style Selector="Button.card-delete:pointerover">
            <Setter Property="Foreground" Value="#DC2626"/>
        </Style>

        <!-- ── Custom controls ─────────────────────────────────────────────── -->

        <!-- RibbonGroup: small bold header + content + optional trailing separator -->
        <Style Selector="controls|RibbonGroup">
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel>
                            <TextBlock Text="{TemplateBinding Header}"
                                       FontWeight="Bold" FontSize="10"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                        </StackPanel>
                        <Rectangle Width="1" Fill="{DynamicResource DividerBrush}"
                                   IsVisible="{TemplateBinding ShowSeparator}"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- EstimateCard: bold #N + inline reading (bold numbers) + ✕ delete -->
        <Style Selector="controls|EstimateCard">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="6"
                            Padding="10,1"
                            Margin="0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal" Spacing="14"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Number}"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           MinWidth="36"
                                           VerticalAlignment="Center"/>
                                <TextBlock Name="PART_Reading"
                                           FontSize="11"
                                           TextWrapping="NoWrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Name="PART_Delete"
                                    Classes="card-delete"
                                    ToolTip.Tip="Delete this row">
                                <TextBlock Text="✕" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- CaptureListSection: title / actions / meta / list (list fills).
             A flat pane (no card chrome) — it now fills the whole right pane. -->
        <Style Selector="controls|CaptureListSection">
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border>
                        <Grid RowDefinitions="Auto,Auto,*">
                            <ContentPresenter Grid.Row="0"
                                              Content="{TemplateBinding Actions}"
                                              Margin="0,0,0,8"/>
                            <ContentPresenter Grid.Row="1"
                                              Content="{TemplateBinding Meta}"
                                              Margin="0,0,0,6"/>
                            <ContentPresenter Grid.Row="2"
                                              Content="{TemplateBinding Body}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- StatusDotRow: [Label?] [coloured dot] [content] -->
        <Style Selector="controls|StatusDotRow">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Column="0" Text="{TemplateBinding Label}"
                                   Classes="reading-caption"
                                   VerticalAlignment="Center"
                                   IsVisible="{TemplateBinding Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <Ellipse Grid.Column="1" Width="8" Height="8"
                                 Fill="{Binding State, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource StatusDotBrush}}"
                                 Margin="6,0,8,0" VerticalAlignment="Center"/>
                        <ContentPresenter Grid.Column="2" Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Hyperlink-style button (About dialog links) -->
        <Style Selector="Button.link">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="MinHeight"       Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <Style Selector="Button.link:pointerover /template/ ContentPresenter">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
        </Style>

        <!-- Header-style button used for collapsible card sections -->
        <Style Selector="Button.collapsible-header">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="Padding"                   Value="0"/>
            <Setter Property="MinHeight"                 Value="0"/>
            <Setter Property="HorizontalAlignment"       Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                    Value="Hand"/>
        </Style>
        <Style Selector="Button.collapsible-header:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleHoverBrush}"/>
        </Style>

        <!-- Capture list: bordered, faintly-filled surface so the list region
             reads as a distinct container inside the card -->
        <Style Selector="ListBox.capture-list">
            <Setter Property="Background"      Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="4"/>
        </Style>

        <!-- ── Cards ───────────────────────────────────────────────────────── -->
        <Style Selector="Border.card">
            <Setter Property="Background"   Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="12"/>
            <Setter Property="Margin"       Value="0,8,0,0"/>
        </Style>

    </Application.Styles>
</Application>

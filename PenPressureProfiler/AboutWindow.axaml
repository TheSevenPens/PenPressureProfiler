<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PenPressureProfiler.AboutWindow"
        Title="About Pen Pressure Profiler"
        Width="420" SizeToContent="Height"
        MinWidth="360"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        FontSize="13"
        FontFamily="Segoe UI Variable,Segoe UI,sans-serif">

    <StackPanel Margin="24,20,24,16" Spacing="10">

        <TextBlock Text="Pen Pressure Profiler"
                   FontSize="18" FontWeight="SemiBold"/>

        <TextBlock x:Name="txt_version"
                   Opacity="0.7"
                   Text="Version —"/>

        <TextBlock TextWrapping="Wrap" Opacity="0.8"
                   Text="Measures and records the relationship between physical force (digital scale) and the logical pressure reported by a drawing-tablet driver."/>

        <!-- Links -->
        <StackPanel Spacing="4" Margin="0,6,0,0">
            <Button x:Name="btn_repo"
                    Classes="link"
                    Click="btn_repo_Click"
                    Content="GitHub repository"/>
            <Button x:Name="btn_readme"
                    Classes="link"
                    Click="btn_readme_Click"
                    Content="README / documentation"/>
        </StackPanel>

        <!-- Close -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Click="Close_Click" IsDefault="True"/>
        </StackPanel>

    </StackPanel>
</Window>

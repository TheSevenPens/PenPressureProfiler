<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:controls="clr-namespace:PenPressureProfiler.Controls"
        mc:Ignorable="d"
        x:Class="PenPressureProfiler.MainWindow"
        Title="PenPressureProfiler"
        Height="850"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontSize="13"
        FontFamily="Segoe UI Variable,Segoe UI,sans-serif"
        Background="Transparent"
        DragDrop.AllowDrop="True">

    <Grid x:Name="rootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="119"/>
            <ColumnDefinition Width="201"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left Panel: Tablet Readings ─────────────────────────────── -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10">
            <StackPanel Margin="0,0,0,4">

                <!-- Section header + pen status dot + API selector -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tablet" Classes="section-header" Margin="0"/>
                    <Ellipse Grid.Column="1" x:Name="dot_pen" Width="8" Height="8"
                             Fill="Gray" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="3" x:Name="comboBox_penApi"
                              MinWidth="130" VerticalAlignment="Center"
                              SelectionChanged="comboBox_penApi_SelectionChanged"
                              ToolTip.Tip="WinTab — for tablets in WinTab mode (default for most drivers).&#x0a;Avalonia Pointer — for tablets in Windows Ink mode (enable 'Use Windows Ink' in driver settings)."/>
                </Grid>

                <!-- Pressure group -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Text="Pressure" Classes="group-header"/>
                        <controls:LabeledReading x:Name="reading_pressure_raw"    Caption="Log Pressure (raw):"/>
                        <controls:LabeledReading x:Name="reading_pressure_norm"   Caption="Log Pressure (norm):"/>
                        <controls:LabeledReading x:Name="reading_pressure_smooth" Caption="Log Pressure (smooth):"/>
                        <controls:LabeledReading x:Name="reading_pen_rate" Caption="Pen rate:"/>
                        <ProgressBar x:Name="pressureBar" Minimum="0" Maximum="100" Value="0"
                                     Height="8" Margin="0,6,0,2"/>
                        <controls:LabeledReading x:Name="reading_force"      Caption="Phys Pressure:"/>
                        <controls:LabeledReading x:Name="reading_scale_rate" Caption="Scale rate:"/>
                    </StackPanel>
                </Border>

                <!-- Orientation group -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Text="Orientation" Classes="group-header"/>
                        <controls:LabeledReading x:Name="reading_azimuth"  Caption="Azimuth:"/>
                        <controls:LabeledReading x:Name="reading_altitude" Caption="Altitude:"/>
                        <controls:LabeledReading x:Name="reading_tiltx"    Caption="Tilt X:"/>
                        <controls:LabeledReading x:Name="reading_tilty"    Caption="Tilt Y:"/>
                    </StackPanel>
                </Border>

                <!-- Button State group -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Text="Button State" Classes="group-header"/>
                        <CheckBox x:Name="checkBox_tipdown"         Content="Tip"     Margin="0,1" IsEnabled="False"/>
                        <CheckBox x:Name="checkBox_lowerbuttondown" Content="Button1" Margin="0,1" IsEnabled="False"/>
                        <CheckBox x:Name="checkBox_upperbuttondown" Content="Button2" Margin="0,1" IsEnabled="False"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Scale control group -->
            <Border Classes="card">
                <StackPanel>
                    <!-- Section header + scale status dot -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Scale control" Classes="group-header" Margin="0"/>
                        <Ellipse x:Name="dot_scale" Width="8" Height="8"
                                 Fill="Gray" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="COM Port:" Classes="reading-caption" Margin="0,0,8,0"/>
                        <ComboBox x:Name="comboBoxcomport" Grid.Column="1"/>
                    </Grid>

                    <Button x:Name="button_scale_toggle" Content="▶  Start (Ctrl+T)" Click="button_scale_toggle_Click"/>
                </StackPanel>
            </Border>

            <!-- Logging group -->
            <Border Classes="card">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Logging" Classes="group-header" Margin="0"/>
                        <Ellipse x:Name="dot_logging" Width="8" Height="8"
                                 Fill="Gray" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Documents\PenPressureProfiler\Logs\"
                               Classes="reading-caption" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="button_logging_toggle"   Content="▶  Start Logging (Ctrl+G)" Click="button_logging_toggle_Click" Margin="0,0,6,0"/>
                        <Button x:Name="button_open_logs_folder" Content="Open Folder"               Click="button_open_logs_folder_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ── Center Panel: Chart ──────────────────────────────────────── -->
        <Grid Grid.Row="1" Grid.Column="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab strip + axis range on same row -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                    <Button x:Name="tab_manual"     Content="Manual"     Classes="tab-active" Click="tab_manual_Click"/>
                    <Button x:Name="tab_sweep"       Content="Sweep"                          Click="tab_sweep_Click"/>
                    <Button x:Name="tab_sweep_data"  Content="Sweep Data"                     Click="tab_sweep_data_Click"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="Axis Range:" Classes="reading-caption"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="comboBox_axisRange" Grid.Column="3"
                          SelectedIndex="0" SelectionChanged="comboBox_axisRange_SelectionChanged">
                    <ComboBoxItem Content="Default"/>
                    <ComboBoxItem Content="Full"/>
                    <ComboBoxItem Content="IAF"/>
                    <ComboBoxItem Content="IAF Large"/>
                    <ComboBoxItem Content="Max"/>
                </ComboBox>
                <ComboBox x:Name="comboBox_sweepAxisRange" Grid.Column="3" IsVisible="False"
                          SelectedIndex="0" SelectionChanged="comboBox_sweepAxisRange_SelectionChanged">
                    <ComboBoxItem Content="Default"/>
                    <ComboBoxItem Content="Full"/>
                    <ComboBoxItem Content="IAF"/>
                    <ComboBoxItem Content="IAF Large"/>
                    <ComboBoxItem Content="Max"/>
                </ComboBox>
            </Grid>

            <!-- ── Manual panel ─────────────────────────────────────────── -->
            <Grid x:Name="panel_manual" Grid.Row="1">
                <sp:AvaPlot x:Name="plotView1" MinHeight="300"/>
            </Grid>

            <!-- ── Sweep panel ──────────────────────────────────────────── -->
            <Grid x:Name="panel_sweep" Grid.Row="1" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <sp:AvaPlot Grid.Row="0" x:Name="sweepPlotView" MinHeight="300"/>

                <!-- Stability settings card -->
                <Border Grid.Row="1" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Stability settings" Classes="group-header"/>

                        <Grid ColumnDefinitions="150,*,60" Margin="0,3">
                            <TextBlock Grid.Column="0" Text="Pen tolerance:" Classes="reading-caption"/>
                            <Slider    Grid.Column="1" x:Name="slider_penTolerance"
                                       Minimum="0.005" Maximum="0.10" Value="0.03"
                                       ValueChanged="OnSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="label_penTolerance"
                                       Text="3.0%" Classes="reading-value" Margin="6,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="150,*,60" Margin="0,3">
                            <TextBlock Grid.Column="0" Text="Scale tolerance:" Classes="reading-caption"/>
                            <Slider    Grid.Column="1" x:Name="slider_scaleTolerance"
                                       Minimum="0.5" Maximum="30" Value="5"
                                       ValueChanged="OnSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="label_scaleTolerance"
                                       Text="5.0 gf" Classes="reading-value" Margin="6,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="150,*,60" Margin="0,3">
                            <TextBlock Grid.Column="0" Text="Stable duration:" Classes="reading-caption"/>
                            <Slider    Grid.Column="1" x:Name="slider_stableTicks"
                                       Minimum="100" Maximum="2000" Value="400"
                                       ValueChanged="OnSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="label_stableTicks"
                                       Text="400 ms" Classes="reading-value" Margin="6,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="150,*,60" Margin="0,3">
                            <TextBlock Grid.Column="0" Text="Min capture gap:" Classes="reading-caption"/>
                            <Slider    Grid.Column="1" x:Name="slider_minGap"
                                       Minimum="200" Maximum="3000" Value="500"
                                       ValueChanged="OnSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="label_minGap"
                                       Text="500 ms" Classes="reading-value" Margin="6,0,0,0"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="12">
                            <TextBlock x:Name="label_captureCount"
                                       Text="0 stable captures" Classes="reading-caption"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="button_clearSweep" Content="Clear (Ctrl+W)"
                                    Click="button_clearSweep_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Sweep Data panel ─────────────────────────────────────── -->
            <Grid x:Name="panel_sweep_data" Grid.Row="1" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Capture list -->
                <DataGrid x:Name="sweepDataGrid" Grid.Row="0"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" BorderThickness="0"
                          SelectionChanged="sweepDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"           Binding="{Binding Index}"      Width="35"/>
                        <DataGridTextColumn Header="Physical gf" Binding="{Binding PhysicalGf}" Width="*"/>
                        <DataGridTextColumn Header="Logical %"   Binding="{Binding LogicalPct}" Width="*"/>
                        <DataGridTextColumn Header="Pen range"   Binding="{Binding PenRange}"   Width="*"/>
                        <DataGridTextColumn Header="Scale range" Binding="{Binding ScaleRange}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Detail panel for selected capture -->
                <Border x:Name="sweepDetailPanel" Grid.Row="1" Classes="card" IsVisible="False">
                    <StackPanel>
                        <TextBlock x:Name="label_sweepDetail_pen"
                                   Classes="reading-caption" TextWrapping="Wrap"/>
                        <TextBlock x:Name="label_sweepDetail_penValues"
                                   Classes="reading-value" TextWrapping="Wrap"
                                   Margin="0,2,0,8" FontFamily="Consolas,monospace"/>
                        <TextBlock x:Name="label_sweepDetail_scale"
                                   Classes="reading-caption" TextWrapping="Wrap"/>
                        <TextBlock x:Name="label_sweepDetail_scaleValues"
                                   Classes="reading-value" TextWrapping="Wrap"
                                   Margin="0,2,0,0" FontFamily="Consolas,monospace"/>
                    </StackPanel>
                </Border>

                <!-- Save / Load -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0" Spacing="6">
                    <Button x:Name="button_saveSweepData" Content="Save Snapshots" Click="button_saveSweepData_Click"/>
                    <Button x:Name="button_loadSweepData" Content="Load Snapshots" Click="button_loadSweepData_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ── Right Panel: Data Recording ─────────────────────────────── -->
        <ScrollViewer Grid.Row="1" Grid.Column="3" Margin="10"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Data" Classes="section-header"/>

                <!-- Action buttons -->
                <WrapPanel Margin="0,0,0,8">
                    <Button x:Name="button_record"          Content="Record (Ctrl+R)"    Click="button_record_Click"           Margin="0,0,4,4"/>
                    <Button x:Name="button_load_sample_data" Content="Sample (Ctrl+L)"   Click="button_load_sample_data_Click" Margin="0,0,4,4"/>
                    <Button x:Name="button_clearlast"        Content="Clear Last (Ctrl+C)" Click="button_clearlast_Click"      Margin="0,0,4,4"/>
                    <Button x:Name="button_clearlog"         Content="Clear All (Ctrl+A)" Click="button_clearlog_Click"        Margin="0,0,4,4"/>
                    <Button x:Name="button_copytext"         Content="Copy"               Click="button_copytext_Click"        Margin="0,0,4,4"/>
                    <Button x:Name="button_save"             Content="Save (Ctrl+S)"      Click="button_save_Click"            Margin="0,0,4,4" IsEnabled="False"/>
                    <Button x:Name="button_export"           Content="Export"             Click="button_export_Click"/>
                </WrapPanel>

                <!-- Record count -->
                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Records:" Classes="reading-caption" Margin="0,0,8,0"/>
                    <TextBlock x:Name="label_recordcount" Grid.Column="1" Classes="reading-value" Text="0"/>
                </Grid>

                <!-- Data grid -->
                <DataGrid x:Name="dataGrid_records" Height="150"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0" Margin="0,0,0,10"
                          SelectionChanged="dataGrid_records_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Physical (gf)" Binding="{Binding PhysicalPressure, StringFormat=0.0}" Width="*"/>
                        <DataGridTextColumn Header="Logical (%)"   Binding="{Binding LogicalPressure, StringFormat={}{0:P2}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Metadata fields -->
                <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,6">
                    <controls:LabeledField x:Name="field_brand"       Grid.Column="0" Label="Brand:" Text="BRAND"    TextChanged="OnChartTitleFieldChanged"/>
                    <controls:LabeledField x:Name="field_inventoryid" Grid.Column="2" Label="ID:"    Text="--P.0000" TextChanged="OnChartTitleFieldChanged"/>
                </Grid>
                <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,6">
                    <controls:LabeledField x:Name="field_pen"  Grid.Column="0" Label="Pen:"  Text="PEN"/>
                    <controls:LabeledField x:Name="field_user" Grid.Column="2" Label="User:"/>
                </Grid>
                <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,6">
                    <controls:LabeledField x:Name="field_penfamily" Grid.Column="0" Label="Family:"/>
                    <controls:LabeledField x:Name="field_tablet"    Grid.Column="2" Label="Tablet:"/>
                </Grid>
                <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,6">
                    <controls:LabeledField x:Name="field_date"   Grid.Column="0" Label="Date:"   TextChanged="OnChartTitleFieldChanged"/>
                    <controls:LabeledField x:Name="field_driver" Grid.Column="2" Label="Driver:"/>
                </Grid>
                <controls:LabeledField x:Name="field_os"    Label="OS:"    Margin="0,0,0,6"/>
                <controls:LabeledField x:Name="field_tags"  Label="Tags:"  Margin="0,0,0,6"/>

                <StackPanel Margin="0,0,0,6">
                    <TextBlock Text="Notes:" Classes="field-label"/>
                    <TextBox x:Name="textBox_notes" Height="50" TextWrapping="Wrap"
                             Padding="5,3" AcceptsReturn="True"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

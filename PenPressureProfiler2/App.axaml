<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PenPressureProfiler.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />

        <!-- ── Typography ──────────────────────────────────────────────────── -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.group-header">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.reading-caption">
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity"           Value="0.7"/>
        </Style>
        <Style Selector="TextBlock.reading-value">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity"    Value="0.7"/>
            <Setter Property="Margin"     Value="0,8,0,3"/>
        </Style>

        <!-- ── TextBox ─────────────────────────────────────────────────────── -->
        <Style Selector="TextBox">
            <Setter Property="Padding"   Value="6,2"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>

        <!-- ── Buttons ─────────────────────────────────────────────────────── -->
        <Style Selector="Button">
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="MinHeight"    Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.tab-active">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ── Cards ───────────────────────────────────────────────────────── -->
        <Style Selector="Border.card">
            <Setter Property="Background"   Value="#14000000"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="12"/>
            <Setter Property="Margin"       Value="0,8,0,0"/>
        </Style>

    </Application.Styles>
</Application>
